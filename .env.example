# Shopify Configuration
NUXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NUXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token
NUXT_PUBLIC_SHOPIFY_API_VERSION=2024-10

# Shopify Admin API OAuth Client Credentials
# Get these from your Shopify Admin: Settings → Apps and sales channels → Develop apps
# The access token is fetched dynamically using OAuth Client Credentials grant
NUXT_SHOPIFY_CLIENT_ID=your_oauth_client_id
NUXT_SHOPIFY_CLIENT_SECRET=your_oauth_client_secret

# App Configuration
NUXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
